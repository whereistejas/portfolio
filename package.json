{
	"name": "whereistejas",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "bunx --bun astro dev",
		"start": "bunx --bun astro dev",
		"check": "bunx --bun astro check",
		"build": "bunx --bun astro build",
		"build:queue": "bun src/content/refresh-cache.ts",
		"preview": "bunx --bun astro preview",
		"astro": "bunx --bun astro",
		"prettier": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"dependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/react": "^5.0.3",
		"@astrojs/ts-plugin": "1.10.7",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"astro": "6.1.5",
		"exifreader": "^4.38.1",
		"framer-motion": "^12.38.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"rehype-katex": "^7.0.1",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"unified": "^11.0.5"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@types/bun": "^1.3.11",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"prettier": "3.6.2",
		"prettier-plugin-astro": "^0.13.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"zod": "^4.3.6"
	},
	"prettier": {
		"printWidth": 80,
		"tabWidth": 2,
		"useTabs": true,
		"semi": true,
		"singleQuote": false,
		"quoteProps": "as-needed",
		"trailingComma": "es5",
		"bracketSpacing": true,
		"arrowParens": "always",
		"endOfLine": "lf",
		"plugins": [
			"prettier-plugin-astro",
			"prettier-plugin-tailwindcss"
		],
		"overrides": [
			{
				"files": "*.astro",
				"options": {
					"parser": "astro"
				}
			}
		]
	},
	"private": true,
	"peerDependencies": {
		"typescript": "^5"
	}
}
