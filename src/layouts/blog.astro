---
import Page from "./page.astro";
import Textorlink from "../components/textorlink.astro";

const { frontmatter } = Astro.props;
---

<Page title={frontmatter.title as string}>
	<Fragment slot="header">
		<Textorlink content={(frontmatter.title as string).toUpperCase()} />
	</Fragment>
	<Fragment slot="main">
		<meta
			name="fediverse:creator"
			content="@whereistejas@hachyderm.io"
			hidden
		/>
		<article class="blog-article">
			<slot />
		</article>
		<script>
			import { initBlogArticlePretext } from "../scripts/pretext-blog-articles";

			async function runBlogPretext() {
				await initBlogArticlePretext();
			}
			void runBlogPretext();
			document.addEventListener("astro:after-swap", () => void runBlogPretext());
		</script>
	</Fragment>
</Page>
