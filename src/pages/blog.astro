---
import Page from "../layouts/page.astro";
import Textorlink from "../components/textorlink.astro";

type Post = {
	frontmatter: {
		title: string;
		date: Date;
	};
	url: string;
	rawContent: () => string;
};

const posts: Post[] = Object.values(
	import.meta.glob("./posts/*.md", { eager: true })
);

function firstParagraph(post: Post): string {
	const raw = post.rawContent?.();
	if (!raw) return "";
	const blocks = raw.split(/\n\n+/);
	return blocks.find((b) => b.trim() && !b.trim().startsWith("#"))?.trim() ?? "";
}

posts.sort(
	(a, b) =>
		new Date(b.frontmatter.date).getTime() -
		new Date(a.frontmatter.date).getTime()
);
---

<Page title="Blog">
	<Fragment slot="header">
		<Textorlink content="BLOG" transitionName="nav-blog" />
	</Fragment>
	<Fragment slot="main">
		<div class="feed">
			{
				posts.map((post, idx) => (
					<a href={post.url} class="feed-item" style={`--i: ${idx}`}>
						<span class="feed-title">
							{post.frontmatter.title}
						</span>
						{firstParagraph(post) && (
							<span class="feed-desc">
								{firstParagraph(post)}
							</span>
						)}
						<span class="feed-meta">
							{new Date(post.frontmatter.date).toLocaleDateString(
								"en-GB",
								{
									day: "2-digit",
									month: "short",
									year: "numeric",
								}
							)}
						</span>
					</a>
				))
			}
		</div>
	</Fragment>
</Page>
