---
import { getCollection } from "astro:content";
import rehypeStringify from "rehype-stringify";
import Page from "../layouts/page.astro";
import remarkGfm from "remark-gfm";
import remarkParse from "remark-parse";
import remarkRehype from "remark-rehype";
import Textorlink from "../components/textorlink.astro";
import { unified } from "unified";

const archiveEntries = await getCollection("readwise-archive");

const markdownProcessor = unified()
	.use(remarkParse)
	.use(remarkGfm)
	.use(remarkRehype)
	.use(rehypeStringify);

const itemsByDate = new Map<string, (typeof archiveEntries)[number][]>();
for (const entry of archiveEntries) {
	const dateGroup = entry.data.dateGroup;
	if (!itemsByDate.has(dateGroup)) {
		itemsByDate.set(dateGroup, []);
	}
	itemsByDate.get(dateGroup)?.push(entry);
}

const highlightHtmlById = new Map<string, string[]>();
for (const entry of archiveEntries) {
	if (entry.data.highlights.length === 0) {
		continue;
	}
	const html = await Promise.all(
		entry.data.highlights.map(async (highlight: string) =>
			String(await markdownProcessor.process(highlight))
		)
	);
	highlightHtmlById.set(entry.data.readwise_id, html);
}
---

<Page title="Reading Archive">
	<Fragment slot="header">
		<Textorlink content="READING ARCHIVE" />
	</Fragment>
	<Fragment slot="main">
		<div class="archive_wrapper" id="archive-wrapper">
			<div
				class="archive-overlay"
				id="archive-overlay"
				aria-hidden="true"
				tabindex="-1"
			/>
			<div class="feed">
				{
					Array.from(itemsByDate.entries()).map(([date, groupItems]) =>
						groupItems.map((item) => {
							const { title, url, summary, category, readwise_id, highlights } = item.data;
							const hasHighlights = highlights.length > 0;
							const highlightId = readwise_id;
							const highlightsHtml = highlightHtmlById.get(highlightId) ?? [];
							const paneId = `archive-highlights-${highlightId}`;
							const highlightCount = highlights.length;
							const metaParts = [category, date].filter(Boolean);

							return (
								<div
									class:list={[
										"feed-item",
										hasHighlights && "feed-item--with-highlights",
									]}
									data-highlight-id={hasHighlights ? highlightId : undefined}
								>
									{hasHighlights ? (
										<div class="feed-item-card">
											<a href={url} target="_blank" rel="noopener noreferrer" class="feed-title">
												{title}
											</a>
											{summary && <span class="feed-desc">{summary}</span>}
											<span class="feed-meta">
												{metaParts.map((part, i) => (
													<>
														{i > 0 && (
															<span class="text-yellow-700 dark:text-yellow-600">{" · "}</span>
														)}
														{part}
													</>
												))}
												<span class="text-yellow-700 dark:text-yellow-600">{" · "}</span>
												<button
													type="button"
													class="feed-highlight-btn"
													aria-expanded="false"
													aria-controls={paneId}
													data-highlight-toggle
												>
													{highlightCount} {highlightCount === 1 ? "highlight" : "highlights"}
												</button>
											</span>
											<div class="feed-highlights-body" id={paneId}>
												<ul class="feed-highlights-list">
													{highlightsHtml.map((html, i, arr) => (
														<li style={`--i: ${i}; --reverse-i: ${arr.length - 1 - i}`}>
															<blockquote><Fragment set:html={html} /></blockquote>
														</li>
													))}
												</ul>
											</div>
										</div>
									) : (
										<>
											<a href={url} target="_blank" rel="noopener noreferrer" class="feed-title">
												{title}
											</a>
											{summary && <span class="feed-desc">{summary}</span>}
											<span class="feed-meta">
												{metaParts.map((part, i) => (
													<>
														{i > 0 && (
															<span class="text-yellow-700 dark:text-yellow-600">{" · "}</span>
														)}
														{part}
													</>
												))}
											</span>
										</>
									)}
								</div>
							);
						})
					)
				}
			</div>
		</div>

		<script is:inline>
			(() => {
				const wrapper = document.getElementById("archive-wrapper");
				const overlay = document.getElementById("archive-overlay");
				if (!wrapper || !overlay) return;

				const reducedMotion = window.matchMedia(
					"(prefers-reduced-motion: reduce)"
				).matches;

				/** @type {HTMLElement | null} */
				let activeItem = null;
				/** @type {HTMLButtonElement | null} */
				let activeButton = null;

				const ENTER_BASE_DELAY_MS = 120;
				const ENTER_STAGGER_MS = 50;
				const ENTER_ITEM_MS = 400;
				const EXIT_STAGGER_MS = 40;
				const EXIT_ITEM_MS = 320;
				const EXIT_MIN_MS = 280;

				const entryDuration = (count) =>
					ENTER_BASE_DELAY_MS + Math.max(count - 1, 0) * ENTER_STAGGER_MS + ENTER_ITEM_MS;

				const exitDuration = (count) =>
					Math.max((count - 1) * EXIT_STAGGER_MS + EXIT_ITEM_MS, EXIT_MIN_MS);

				const setDurations = (overlayMs, body, bodyMs) => {
					overlay.style.setProperty("--overlay-duration", overlayMs + "ms");
					if (body) body.style.setProperty("--body-duration", bodyMs + "ms");
				};

				const clearDurations = (body) => {
					overlay.style.removeProperty("--overlay-duration");
					if (body) body.style.removeProperty("--body-duration");
				};

				const clearOpenState = (item, body, btn) => {
					item.removeAttribute("data-expanded");
					overlay.removeAttribute("data-visible");
					item.classList.remove("is-highlight-pane-closing");
					if (body) {
						body.removeAttribute("data-open");
						body.style.removeProperty("--body-max-h");
					}
					if (btn) btn.setAttribute("aria-expanded", "false");
					activeItem = null;
					activeButton = null;
				};

				const closePaneImmediate = () => {
					if (!activeItem) return;
					const body = activeItem.querySelector(".feed-highlights-body");
					clearOpenState(activeItem, body, activeButton);
				};

				const closePaneAnimated = () => {
					if (!activeItem) return;
					if (reducedMotion) { closePaneImmediate(); return; }

					const item = activeItem;
					const btn = activeButton;
					const body = item.querySelector(".feed-highlights-body");
					const count = body ? body.querySelectorAll("li").length : 0;
					const ms = exitDuration(count);

					setDurations(ms, body, ms);
					item.classList.add("is-highlight-pane-closing");
					overlay.removeAttribute("data-visible");
					if (body) body.removeAttribute("data-open");

					window.setTimeout(() => {
						clearOpenState(item, body, btn);
						clearDurations(body);
					}, ms);
				};

				/** @param {HTMLElement} item  @param {HTMLButtonElement} button */
				const openPane = (item, button) => {
					if (activeItem && activeItem !== item) closePaneImmediate();
					activeItem = item;
					activeButton = button;

					item.setAttribute("data-expanded", "true");
					button.setAttribute("aria-expanded", "true");

					const body = item.querySelector(".feed-highlights-body");
					if (!body) return;

					const count = body.querySelectorAll("li").length;
					const bodyMs = entryDuration(count);
					setDurations(bodyMs, body, bodyMs);

					body.style.setProperty("--body-max-h", body.scrollHeight + "px");
					overlay.setAttribute("data-visible", "true");

					if (reducedMotion) { body.setAttribute("data-open", "true"); return; }
					window.requestAnimationFrame(() => {
						body.setAttribute("data-open", "true");
					});
				};

				for (const btn of wrapper.querySelectorAll("[data-highlight-toggle]")) {
					if (!(btn instanceof HTMLButtonElement)) continue;
					btn.addEventListener("click", (event) => {
						event.preventDefault();
						const item = btn.closest(".feed-item");
						if (!(item instanceof HTMLElement)) return;
						if (activeItem === item && item.hasAttribute("data-expanded")) {
							closePaneAnimated();
							return;
						}
						openPane(item, btn);
					});
				}

				overlay.addEventListener("click", () => closePaneAnimated());
				window.addEventListener("keydown", (e) => {
					if (e.key === "Escape" && activeItem) closePaneAnimated();
				});
			})();
		</script>
	</Fragment>
</Page>
