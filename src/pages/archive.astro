---
import { getCollection } from "astro:content";
import rehypeStringify from "rehype-stringify";
import Page from "../layouts/page.astro";
import remarkGfm from "remark-gfm";
import remarkParse from "remark-parse";
import remarkRehype from "remark-rehype";
import Textorlink from "../components/textorlink.astro";
import { unified } from "unified";
import HighlightsAccordion from "../components/HighlightsAccordion";

const archiveEntries = await getCollection("readwise-archive");

const markdownProcessor = unified()
	.use(remarkParse)
	.use(remarkGfm)
	.use(remarkRehype)
	.use(rehypeStringify);

const itemsByDate = new Map<string, (typeof archiveEntries)[number][]>();
for (const entry of archiveEntries) {
	const dateGroup = entry.data.dateGroup;
	if (!itemsByDate.has(dateGroup)) {
		itemsByDate.set(dateGroup, []);
	}
	itemsByDate.get(dateGroup)?.push(entry);
}

const highlightHtmlById = new Map<string, string[]>();
for (const entry of archiveEntries) {
	if (entry.data.highlights.length === 0) {
		continue;
	}
	const html = await Promise.all(
		entry.data.highlights.map(async (highlight: string) =>
			String(await markdownProcessor.process(highlight))
		)
	);
	highlightHtmlById.set(entry.data.readwise_id, html);
}
---

<Page title="Reading Archive">
	<Fragment slot="header">
		<Textorlink content="READING ARCHIVE" />
	</Fragment>
	<Fragment slot="main">
		<div class="archive_wrapper" id="archive-wrapper">
			<div
				class="archive-overlay"
				id="archive-overlay"
				aria-hidden="true"
				tabindex="-1"
			/>
			<div class="feed">
				{
					Array.from(itemsByDate.entries()).map(([date, groupItems]) =>
						groupItems.map((item) => {
							const { title, url, summary, category, readwise_id, highlights, author } = item.data;
							const hasHighlights = highlights.length > 0;
							const highlightId = readwise_id;
							const highlightsHtml = highlightHtmlById.get(highlightId) ?? [];
							const paneId = `archive-highlights-${highlightId}`;
							const highlightCount = highlights.length;
							const authors = [...new Set(
								author.split(/\s*[,&]\s*/)
									.map((a: string) => a.trim())
									.filter((a: string) => a && a.toLowerCase() !== "unknown" && !/^[a-z0-9-]+(\.[a-z0-9-]+)+$/i.test(a))
							)];
							const displayCategory = category === "epub" ? "book" : category;
							const metaParts = [date, ...authors].filter(Boolean);

							return (
								<div
									class:list={[
										"feed-item",
										hasHighlights && "feed-item--with-highlights",
									]}
									data-highlight-id={hasHighlights ? highlightId : undefined}
								>
									{hasHighlights ? (
										<div class="feed-item-card">
											<a href={url} target="_blank" rel="noopener noreferrer" class="feed-title">
												{title}
											</a>
											{summary && <span class="feed-desc">{summary}</span>}
											<span class="feed-meta">
												{displayCategory && (
													<span class="hidden md:inline">
														{displayCategory}
														<span class="text-yellow-700 dark:text-yellow-600">{" · "}</span>
													</span>
												)}
												{metaParts.map((part, i) => (
													<>
														{i > 0 && (
															<span class="text-yellow-700 dark:text-yellow-600">{" · "}</span>
														)}
														{part}
													</>
												))}
												</span>
											<HighlightsAccordion
												client:load
												highlightsHtml={highlightsHtml}
												highlightId={highlightId}
												paneId={paneId}
											/>
										</div>
									) : (
										<>
											<a href={url} target="_blank" rel="noopener noreferrer" class="feed-title">
												{title}
											</a>
											{summary && <span class="feed-desc">{summary}</span>}
											<span class="feed-meta">
												{displayCategory && (
													<span class="hidden md:inline">
														{displayCategory}
														<span class="text-yellow-700 dark:text-yellow-600">{" · "}</span>
													</span>
												)}
												{metaParts.map((part, i) => (
													<>
														{i > 0 && (
															<span class="text-yellow-700 dark:text-yellow-600">{" · "}</span>
														)}
														{part}
													</>
												))}
											</span>
										</>
									)}
								</div>
							);
						})
					)
				}
			</div>
		</div>


	</Fragment>
</Page>
