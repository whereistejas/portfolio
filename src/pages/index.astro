---
import Carousel from "../components/carousel.astro";
import Textorlink from "../components/textorlink.astro";
import Page from "../layouts/page.astro";
---

<Page title={undefined}>
	<Fragment slot="header">
		<Textorlink content="INBOX" href="/inbox" transitionName="nav-inbox" />
		<Textorlink content="BLOG" href="/blog" transitionName="nav-blog" />
	</Fragment>

	<Fragment slot="main">
		<Carousel />
	</Fragment>

	<Fragment slot="footer">
		<Textorlink content="ARCHIVE" href="/archive" transitionName="nav-archive" />
		<Textorlink content="INFO" href="/info" transitionName="nav-info" />
	</Fragment>
</Page>
