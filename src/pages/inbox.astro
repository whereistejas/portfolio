---
import { getCollection } from "astro:content";
import Page from "../layouts/page.astro";
import Textorlink from "../components/textorlink.astro";

const queueEntries = await getCollection("readwise-queue");
queueEntries.sort((a, b) => a.data.order - b.data.order);
---

<Page title="Reading Inbox">
	<Fragment slot="header">
		<Textorlink content="READING INBOX" />
	</Fragment>
	<Fragment slot="main">
		<div class="feed">
			{
				queueEntries.map((item) => {
					const { author, category, dateGroup } = item.data;
					const authors = [...new Set(
						author.split(/\s*[,&]\s*/)
							.map((a: string) => a.trim())
							.filter((a: string) => a && a.toLowerCase() !== "unknown" && !/^[a-z0-9-]+(\.[a-z0-9-]+)+$/i.test(a))
					)];
					const displayCategory = category === "epub" ? "book" : category;
					const sortedTags = [...item.data.display_tags].sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));
					const metaParts = [dateGroup, ...authors].filter(Boolean);

					return (
						<div class="feed-item">
						<a
							href={item.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="feed-title"
						>
							{item.data.title}
						</a>
							{item.data.summary && (
								<span class="feed-desc">{item.data.summary}</span>
							)}
						<span class="feed-meta">
							{displayCategory && (
								<span class="hidden md:inline">
									{displayCategory}
									<span class="text-yellow-700 dark:text-yellow-600">
										{" · "}
									</span>
								</span>
							)}
							{metaParts.map((part, i) => (
								<>
									{i > 0 && (
										<span class="text-yellow-700 dark:text-yellow-600">
											{" · "}
										</span>
									)}
									{part}
								</>
							))}
						</span>
						{sortedTags.length > 0 && (
							<span class="feed-tags">
								{sortedTags.map((tag, i) => (
									<>
										{i > 0 && (
											<span class="text-yellow-700 dark:text-yellow-600">
												{" · "}
											</span>
										)}
										{tag.toLowerCase()}
									</>
								))}
							</span>
						)}
						</div>
					);
				})
			}
		</div>
	</Fragment>
</Page>
