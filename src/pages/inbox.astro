---
import { getCollection } from "astro:content";
import Page from "../layouts/page.astro";
import Textorlink from "../components/textorlink.astro";

const queueEntries = await getCollection("readwise-queue");
queueEntries.sort((a, b) => a.data.order - b.data.order);
---

<Page title="Reading Inbox">
	<Fragment slot="header">
		<Textorlink content="READING INBOX" />
	</Fragment>
	<Fragment slot="main">
		<div class="feed">
			{
				queueEntries.map((item) => (
					<div class="feed-item">
						<div class="flex items-baseline gap-0.5">
							<a
								href={item.data.url}
								target="_blank"
								rel="noopener noreferrer"
								class="feed-title min-w-0"
							>
								{item.data.title}
							</a>
							<a
								href={`https://read.readwise.io/new/read/${item.data.readwise_id}`}
								target="_blank"
								rel="noopener noreferrer"
								class="feed-readwise shrink-0"
							>
								Ⓡ
							</a>
						</div>
						{item.data.summary && (
							<span class="feed-desc">{item.data.summary}</span>
						)}
					<span class="feed-tags">
						{[...item.data.display_tags]
							.sort((a, b) =>
								a.toLowerCase().localeCompare(b.toLowerCase())
							)
							.map((tag, i) => (
								<>
									{i > 0 && (
										<span class="text-yellow-700 dark:text-yellow-600">
											{" · "}
										</span>
									)}
									{tag.toLowerCase()}
								</>
							))}
					</span>
					</div>
				))
			}
		</div>
	</Fragment>
</Page>
